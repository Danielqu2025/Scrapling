# Copy to .env and edit. Loaded by run.sh / run.ps1.

# Bind
SH_EIA_HOST=127.0.0.1
SH_EIA_PORT=8080

# Auth: set to 1 for public deployment; leave 0 for local/dev
SH_EIA_AUTH_ENABLED=0
SH_EIA_JWT_SECRET=change-me-to-a-long-random-string
SH_EIA_ADMIN_USERNAME=admin
SH_EIA_ADMIN_PASSWORD=change-me-strong-password

# Sync behaviour
SH_EIA_SYNC_HOURS=0
SH_EIA_SYNC_MAX_PAGES=1
SH_EIA_STARTUP_CHECK=1
SH_EIA_STARTUP_CHECK_MODE=remind

# Public hostname (documentation / nginx placeholder; not read by the app)
# SH_EIA_PUBLIC_HOST=eia.example.com
