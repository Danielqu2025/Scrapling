{
  "id": "noc_gb_monitor",
  "display_name": "标准公告查询",
  "exe_name": "NocGbMonitor",
  "entry_script": "portable_launcher.py",
  "package_suffix": "_portable",
  "include_paths": ["."],
  "include_repo_root": false,
  "add_data": [
    {"from": "app/static", "to": "app/static"},
    {"from": "config.example.json", "to": "config.example.json"}
  ],
  "hidden_imports": [
    "uvicorn.logging",
    "uvicorn.loops.auto",
    "uvicorn.protocols.http.auto",
    "uvicorn.lifespan.on",
    "uvicorn.lifespan.off",
    "email.mime.multipart",
    "email.mime.text",
    "email.mime.application",
    "multipart",
    "openpyxl"
  ],
  "collect_all": [],
  "bundle_sqlite": false,
  "bundle_playwright_browsers": false,
  "seed_data": [
    {"from": "config.example.json", "to": "config.example.json"}
  ],
  "readme_template": "{title} - 便携版\n\n【使用】\n1. 双击 {exe_name}.exe\n2. 浏览器会自动打开；若未打开，请访问 http://127.0.0.1:8765\n3. 关闭黑色命令行窗口即可退出\n\n【邮件通知（可选）】\n- 复制 config.example.json 为 config.json 并填写 SMTP 邮箱\n- 命令行运行 monitor.py 可抓取并发送邮件\n\n【说明】\n- 导出 Excel 保存在 output 文件夹\n- 需要能访问国家标准全文公开系统等官网\n"
}
